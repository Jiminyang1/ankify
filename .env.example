# --- Turso (libSQL) ---
# Run `turso db create ankify` then `turso db show ankify --url` and `turso db tokens create ankify`.
TURSO_DATABASE_URL="libsql://your-db.turso.io"
TURSO_AUTH_TOKEN="your-token"

# Local dev fallback: leave the two above empty and set this to use a local SQLite file
# LOCAL_DB_PATH="./local.db"

# --- AI providers (set one or more; the active one is chosen in dashboard settings) ---
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
DEEPSEEK_API_KEY=""

# --- Extension <-> Web auth (single-user V1) ---
# Random string the extension sends in X-Ankify-Token; web verifies.
ANKIFY_API_TOKEN="generate-a-random-string"

# Random string you type into the web login page. Required in production.
APP_PASSWORD="generate-another-random-string"

# Where the extension talks to the web app
NEXT_PUBLIC_API_BASE_URL="http://localhost:3000"
