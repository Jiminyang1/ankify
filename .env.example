# --- Turso (libSQL) ---
# Run `turso db create ankify` then `turso db show ankify --url` and `turso db tokens create ankify`.
TURSO_DATABASE_URL=""
TURSO_AUTH_TOKEN=""

# Local dev fallback: leave the two above empty and set this to use a local SQLite file
LOCAL_DB_PATH="./packages/db/local.db"

# --- Auth ---
BETTER_AUTH_SECRET="generate-a-long-random-string"
BETTER_AUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
ANKIFY_ALLOWED_EMAILS="you@example.com"

# --- Per-user AI key encryption ---
# 32+ random bytes encoded as base64, hex, or plain text. Used only to encrypt
# user-provided provider keys before writing them to the DB.
AI_KEY_ENCRYPTION_SECRET="generate-another-long-random-string"

# User-owned AI provider keys are configured in the Settings page, not env.
