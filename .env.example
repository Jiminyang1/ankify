# Two-profile env layout. Copy each block into its own file:
#
#   .env.local              ← used by `pnpm dev` + `pnpm db:migrate` (LOCAL profile)
#   .env.production.local   ← used by `pnpm db:migrate:prod` only   (PRODUCTION profile)
#
# Production runtime (Vercel) reads env vars from the Vercel dashboard, not
# from any file in this repo.

# ─── LOCAL profile (.env.local) ──────────────────────────────────────────────
# Local dev uses a SQLite file. Leave Turso vars empty.
TURSO_DATABASE_URL=""
TURSO_AUTH_TOKEN=""
LOCAL_DB_PATH="packages/db/local.db"

BETTER_AUTH_SECRET="generate-a-long-random-string"
BETTER_AUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
ANKIFY_ALLOWED_EMAILS="you@example.com"

# 32+ random bytes (base64 / hex / plain). Local DB has its own settings, so
# this can differ from the prod secret without breaking decryption.
AI_KEY_ENCRYPTION_SECRET="generate-another-long-random-string"

# ─── PRODUCTION profile (.env.production.local) ──────────────────────────────
# Only needed locally so you can run prod migrations: `pnpm db:migrate:prod`.
# Do NOT commit. Keep these in sync with the Vercel env dashboard.
#
# TURSO_DATABASE_URL="libsql://<your-db>.turso.io"
# TURSO_AUTH_TOKEN="<from `turso db tokens create`>"
# BETTER_AUTH_SECRET="<same secret as Vercel>"
# BETTER_AUTH_URL="https://your-domain.vercel.app"
# GOOGLE_CLIENT_ID="<same as Vercel>"
# GOOGLE_CLIENT_SECRET="<same as Vercel>"
# ANKIFY_ALLOWED_EMAILS="you@example.com"
# AI_KEY_ENCRYPTION_SECRET="<MUST match Vercel — losing this orphans every stored AI key>"
